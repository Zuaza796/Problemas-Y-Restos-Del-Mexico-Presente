<file path="src/components/TopicPageScaffold.jsx">
import { Link } from 'react-router-dom'
import { topicImages } from '../data/topicImages'
import Breadcrumb from './Breadcrumb'
import InsightCard from './InsightCard'
import PageHero from './PageHero'
import PageLayout from './PageLayout'
import ResponsiveTable from './ResponsiveTable'
import VisualPanel from './VisualPanel'

function FlowDiagram({ items }) {
  if (!items?.length) return null

  return (
    <div className="flow-diagram" role="list" aria-label="Secuencia visual">
      {items.map((item) => (
        <div className="flow-step" role="listitem" key={item}>
          {item}
        </div>
      ))}
    </div>
  )
}

function MatrixPanel({ matrix }) {
  if (!matrix) return null

  return (
    <VisualPanel title={matrix.title} description="Lectura cualitativa, sin porcentajes inventados.">
      <div className="matrix-grid">
        {matrix.items.map(([label, status]) => (
          <div className="matrix-item" key={label}>
            <span>{label}</span>
            <strong>{status}</strong>
          </div>
        ))}
      </div>
    </VisualPanel>
  )
}

function InfoCardGrid({ title, eyebrow, items, variant = 'default' }) {
  if (!items?.length) return null

  return (
    <section className={`narrative-section narrative-${variant}`}>
      <div className="container">
        <div className="section-intro">
          {eyebrow ? <p className="eyebrow">{eyebrow}</p> : null}
          <h2>{title}</h2>
        </div>
        <div className="row g-4">
          {items.map((item) => (
            <div className="col-md-6 col-xl-4" key={item.title}>
              <article className="narrative-card reveal">
                <h3>{item.title}</h3>
                <p>{item.text}</p>
              </article>
            </div>
          ))}
        </div>
      </div>
    </section>
  )
}

function InstitutionCards({ institutions, intro }) {
  if (!institutions?.length) return null

  return (
    <VisualPanel title="¿Por qué importan los organismos autónomos?" description={intro}>
      <div className="row g-4">
        {institutions.map((institution) => (
          <div className="col-md-6 col-xl-4" key={institution.name}>
            <article className="institution-card">
              <p className="meta-label">{institution.area}</p>
              <h3>{institution.name}</h3>
              <dl>
                <dt>Función</dt>
                <dd>{institution.function}</dd>
                <dt>Riesgo</dt>
                <dd>{institution.risk}</dd>
              </dl>
            </article>
          </div>
        ))}
      </div>
    </VisualPanel>
  )
}

function TopicPageScaffold({ topic, charts, dataCards, extraPanels, afterSummary }) {
  const hasCharts = Boolean(charts)
  const hasDataCards = Boolean(dataCards)
  const hasVisualContent =
    hasCharts ||
    hasDataCards ||
    topic.matrix ||
    topic.flow ||
    extraPanels ||
    topic.institutions ||
    topic.judicial ||
    topic.callout ||
    topic.table

  let visualEyebrow = 'Lectura visual'
  let visualTitle = 'Lectura visual del problema'
  let visualDescription =
    'Los recursos visuales se usan para explicar relaciones, magnitudes o secuencias que ayudan a entender el tema.'

  if (hasCharts && hasDataCards) {
    visualTitle = 'Datos clave y visualizaciones'
    visualDescription =
      'Las gráficas se reservan para comparaciones o tendencias; los datos puntuales se muestran como tarjetas.'
  } else if (hasCharts) {
    visualEyebrow = 'Gráfica relevante'
    visualTitle = 'Dato comparativo central'
    visualDescription =
      'Esta gráfica se mantiene porque ayuda a dimensionar una tendencia, diferencia o magnitud importante.'
  } else if (hasDataCards) {
    visualEyebrow = 'Datos clave'
    visualTitle = 'Cifras para dimensionar'
    visualDescription =
      'Estos datos se entienden mejor como tarjetas acompañadas de explicación, no como gráficas.'
  }

  return (
    <PageLayout title={topic.navLabel}>
      <Breadcrumb current={topic.navLabel} />
      <PageHero
        eyebrow={topic.eyebrow}
        title={topic.title}
        summary={topic.summary}
        image={topicImages[topic.imageKey]}
      />

      <section className="section-block">
        <div className="container">
          <div className="row g-5 align-items-start">
            <div className="col-lg-7">
              <article className="topic-copy reveal">
                <p className="eyebrow">Introducción del problema</p>
                <h2>Cuál es el problema</h2>
                <p className="topic-summary">{topic.problemIntro || topic.body}</p>
              </article>
            </div>
            <div className="col-lg-5">
              <article className="key-idea-panel reveal">
                <p className="eyebrow">Idea clave</p>
                <h3>{topic.keyIdea}</h3>
              </article>
              <div className="insight-stack mt-4">
                {topic.insights?.slice(0, 3).map((insight) => (
                  <InsightCard key={insight.title} {...insight} />
                ))}
              </div>
            </div>
          </div>
          {afterSummary}
        </div>
      </section>

      <InfoCardGrid title="Por qué ocurre" eyebrow="Causas principales" items={topic.causes} />

      <InfoCardGrid
        title="Consecuencias reales para México"
        eyebrow="Efectos"
        items={topic.consequences}
        variant="consequences"
      />

      {hasVisualContent ? (
        <section className="section-block section-muted">
          <div className="container">
            <div className="section-intro">
              <p className="eyebrow">{visualEyebrow}</p>
              <h2>{visualTitle}</h2>
              <p>{visualDescription}</p>
            </div>
            {hasCharts ? <div className="chart-grid focused-chart-grid">{charts}</div> : null}
            {hasDataCards ? <div className="row g-4 data-card-row">{dataCards}</div> : null}
            <MatrixPanel matrix={topic.matrix} />
            {topic.flow ? (
              <VisualPanel title="Flujo de causa y consecuencia">
                <FlowDiagram items={topic.flow} />
              </VisualPanel>
            ) : null}
            {extraPanels}
            <InstitutionCards institutions={topic.institutions} intro={topic.institutionsIntro} />
            {topic.judicial ? (
              <VisualPanel
                title="Poder Judicial"
                description="Dimensiones clave para sostener confianza y profesionalismo."
              >
                <div className="pill-grid">
                  {topic.judicial.map((item) => (
                    <span key={item}>{item}</span>
                  ))}
                </div>
              </VisualPanel>
            ) : null}
            {topic.callout ? (
              <article className="info-callout reveal">
                <div className="card-icon" aria-hidden="true">
                  <i className="bi bi-question-circle"></i>
                </div>
                <div>
                  <h3>{topic.callout.title}</h3>
                  <p>{topic.callout.text}</p>
                </div>
              </article>
            ) : null}
            <ResponsiveTable table={topic.table} title="Lectura por áreas" />
          </div>
        </section>
      ) : null}

      <section className="section-block">
        <div className="container">
          <div className="row g-4">
            <div className="col-lg-5">
              <div className="section-intro">
                <p className="eyebrow">Retos actuales</p>
                <h2>Lo que debe resolverse</h2>
              </div>
            </div>
            <div className="col-lg-7">
              <div className="challenge-list">
                {topic.realChallenges?.map((challenge) => (
                  <article className="challenge-row challenge-row-expanded reveal" key={challenge.title}>
                    <i className="bi bi-arrow-right-short" aria-hidden="true"></i>
                    <div>
                      <h3>{challenge.title}</h3>
                      <p>{challenge.text}</p>
                    </div>
                  </article>
                ))}
              </div>
            </div>
          </div>
        </div>
      </section>

      <section className="section-block connections-section">
        <div className="container">
          <article className="connections-panel reveal">
            <p className="eyebrow">Cómo se conecta con otros problemas</p>
            <h2>Relaciones entre temas</h2>
            <p>{topic.connections}</p>
          </article>
        </div>
      </section>

      <section className="section-block meaning-section">
        <div className="container">
          <article className="meaning-panel reveal">
            <div>
              <p className="eyebrow">Cierre del tema</p>
              <h2>Reflexión</h2>
              <p>{topic.conclusion || topic.meaning}</p>
            </div>
            <div className="page-actions">
              <Link className="btn btn-outline-custom" to="/">
                <i className="bi bi-house-door" aria-hidden="true"></i>
                Volver al inicio
              </Link>
              <Link className="btn btn-primary-custom" to={topic.nextPath}>
                Ver {topic.nextLabel}
                <i className="bi bi-arrow-right" aria-hidden="true"></i>
              </Link>
            </div>
          </article>
        </div>
      </section>
    </PageLayout>
  )
}

